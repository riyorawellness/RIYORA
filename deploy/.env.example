# =============================================================================
# RIYORA Wellness — Production environment variables (VPS)
# =============================================================================
# 1. Copy this file:              cp .env.example .env
# 2. Fill in every placeholder    (never commit .env)
# 3. Run deploy:                  ./scripts/deploy.sh
#
# Everything marked ⚠️ is REQUIRED. The others have sensible defaults.

# ----- Domain & CORS ---------------------------------------------------------
# ⚠️ Your production domain (no scheme, no trailing slash)
DOMAIN=app.riyorawellness.com
LETSENCRYPT_EMAIL=you@example.com

# ⚠️ Full origin the frontend uses to call the backend (must match DOMAIN)
REACT_APP_BACKEND_URL=https://app.riyorawellness.com
CORS_ORIGINS=https://app.riyorawellness.com

# ----- MongoDB ---------------------------------------------------------------
# ⚠️ Choose a strong password (16+ chars, mixed)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_TO_STRONG_MONGO_PASSWORD
# MONGO_URL is auto-composed inside docker-compose; do not set here.
DB_NAME=riyora_prod

# ----- JWT -------------------------------------------------------------------
# ⚠️ Generate with:  openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ----- Admin seed (first-run only) ------------------------------------------
# ⚠️ Change AFTER first login
ADMIN_MOBILE=9999999999
ADMIN_PASSWORD=CHANGE_ME_AFTER_FIRST_LOGIN

# ----- Firebase Authentication ----------------------------------------------
# Backend Admin SDK — mounts the JSON file from ../backend/firebase-admin.json
FIREBASE_ADMIN_CREDENTIALS_PATH=/app/firebase-admin.json
# ⚠️ Your Firebase project id (from Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=CHANGE_ME_FIREBASE_PROJECT_ID

# Frontend Web SDK — baked into the React bundle at build time
# ⚠️ Copy from Firebase Console → Project Settings → Your apps → Web app config
REACT_APP_FIREBASE_API_KEY=CHANGE_ME_FIREBASE_API_KEY
REACT_APP_FIREBASE_AUTH_DOMAIN=CHANGE_ME.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=CHANGE_ME_FIREBASE_PROJECT_ID
REACT_APP_FIREBASE_STORAGE_BUCKET=CHANGE_ME.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
REACT_APP_FIREBASE_APP_ID=CHANGE_ME

# ----- Razorpay --------------------------------------------------------------
RAZORPAY_MOCK_MODE=false
# ⚠️ Live keys from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=CHANGE_ME_rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=CHANGE_ME_RAZORPAY_SECRET
# ⚠️ Webhook secret from Razorpay dashboard → Settings → Webhooks (shown ONCE)
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_FROM_RAZORPAY_DASHBOARD

# ----- Company / brand -------------------------------------------------------
COMPANY_NAME=RIYORA Wellness
COMPANY_GST_NUMBER=
COMPANY_ADDRESS=
SUPPORT_EMAIL=support@riyorawellness.com

# ----- Miscellaneous ---------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_HEALTH_CHECK=true
